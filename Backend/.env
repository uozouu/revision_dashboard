# ─────────────────────────────────────────────────────────────────────────────
#  ApexLearn · Environment Configuration
#  Copy to .env and fill in your values. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask Core ───────────────────────────────────────────────────────────────
FLASK_APP=app:create_app
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_STRING_MIN_64_CHARS

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://apexlearn:password@localhost:5432/apexlearn_dev
DATABASE_URL_TEST=postgresql://apexlearn:password@localhost:5432/apexlearn_test
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis (Rate limiting, caching, SocketIO message queue) ───────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_DIFFERENT_FROM_SECRET_KEY
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=s
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# ── Security ─────────────────────────────────────────────────────────────────
BCRYPT_LOG_ROUNDS=12
RATE_LIMIT_DEFAULT=200 per day;50 per hour
RATE_LIMIT_AUTH=10 per minute
RATE_LIMIT_AI=30 per minute
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_CONTENT_LENGTH_MB=10

# ── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_FOLDER=./uploads
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,mp3,wav,m4a

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://...
LOG_LEVEL=INFO

# ── Supabase (micro_pdfs_mbbs_ent source) ────────────────────────────────────
SUPABASE_URL=https://hihlmvdnbhqfhtozfenp.supabase.co
SUPABASE_KEY=

# RECOMMENDED: Add direct Postgres connection string from Supabase Dashboard
# Settings → Database → Connection string (URI mode, port 5432 or 6543 for pooler)
# Example: postgresql://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
SUPABASE_DATABASE_URL=
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# ── Anthropic / Socrates Engine ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
SOCRATES_MODEL=claude-sonnet-4-20250514

# ── Socrates System Prompt (override in production) ───────────────────────────
# Leave empty to use the built-in pedagogically-complete default in socrates.py
SOCRATES_SYSTEM_PROMPT=
